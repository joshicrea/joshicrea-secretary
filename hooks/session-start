#!/usr/bin/env bash
# SessionStart hook for joshicrea-secretary plugin
# Injects AI secretary instructions into every session context.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read the main secretary instructions from CLAUDE.md
secretary_content=$(cat "${PLUGIN_ROOT}/CLAUDE.md" 2>&1 || echo "Error reading CLAUDE.md")

# JSON escape
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

secretary_escaped=$(escape_for_json "$secretary_content")

session_context="<EXTREMELY_IMPORTANT>\nYou are an AI secretary (joshicrea-secretary plugin is active).\n\n**The following are your operating instructions. Follow them exactly:**\n\n${secretary_escaped}\n</EXTREMELY_IMPORTANT>"

context_escaped=$(escape_for_json "$session_context")

printf '{"hookSpecificOutput":{"additionalContext":"%s"},"additionalContext":"%s"}' \
    "$context_escaped" \
    "$context_escaped"
